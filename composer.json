{
    "name": "psc-acme/connector-user",
    "description": "Package connector-user for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ConnectorUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/messenger": "^7.0",
        "symfony/symfony": "^6.3",
        "doctrine/orm": "^3.0",
        "ramsey/uuid": "^4.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}